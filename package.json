{
  "name": "phonediary",
  "version": "1.0.0",
  "description": "MERN contact keeper app",
  "main": "server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node server.js",
    "server": "nodemon server.js",
    "ui": "npm start --prefix ui",
    "uiinstall": "npm install --prefix ui",
    "build:ui": "npm run build --prefix ui",
    "build": "npm run uiinstall && npm run build:ui",
    "demo": "DEMO_MODE=true SERVE_UI=true node server.js",
    "dev": "concurrently \"npm run server\" \"npm run ui\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "config": "^3.2.4",
    "express": "^4.17.1",
    "express-validator": "^6.3.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^5.8.1"
  },
  "devDependencies": {
    "concurrently": "^5.0.1",
    "nodemon": "^2.0.2"
  }
}
